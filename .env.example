# Neon Database Configuration (HTTP API)
# Get this from your Neon project settings: https://console.neon.tech
# Example: postgresql://user:password@ep-xxx-123.us-east-2.aws.neon.tech/neondb?sslmode=require
VITE_DATABASE_URL=your_neon_database_url_here

# Cloudinary Configuration (for image uploads)
# Get these from your Cloudinary dashboard: https://cloudinary.com/console
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset_here
